PORT=8080
CLIENT_ORIGIN=http://localhost:5173
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
TARAS_ANTHROPIC_MODEL=claude-sonnet-4-6
# Sectioned pipeline (default on). Set TARAS_FORCE_LEGACY=1 to use the old single-shot generator.
# TARAS_USE_SECTIONED=false
# TARAS_FORCE_LEGACY=1
# Optional cap on estimated output tokens per Taras job (default 280000)
# TARAS_MAX_TOKENS_PER_JOB=280000
# Testing only: set to true/1 to bypass Taras 429 rate+quota limits
# TARAS_DISABLE_LIMITS=true
# Optional for S3-compatible providers (Cloudflare R2, MinIO, Backblaze B2)
# S3_ENDPOINT=
# Public base URL to returned uploaded image URLs, e.g. https://cdn.example.com or https://<bucket>.s3.<region>.amazonaws.com
S3_PUBLIC_BASE_URL=
