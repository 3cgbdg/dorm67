rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      
      match /savedListings/{listingId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Listings (Marketplace)
    match /listings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Announcements (Campus Feed)
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId);
      
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isOwner(resource.data.userId);
      }
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      // Allow reading if the user is one of the participants
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      
      // Allow creating if the user is setting themselves as a participant
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participantIds;
      
      // Allow updating (lastMessage) if user is a participant
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId;
      }
    }

    // AI Tasks Queue
    match /aiTasks/{taskId} {
      allow read, write: if isAuthenticated() && (
        (request.resource != null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // AI Chat History
    match /aiChats/{userId} {
      allow read: if isOwner(userId);
      match /messages/{msgId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Notifications
    match /notifications/{userId} {
      allow read: if isOwner(userId);
      match /items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
