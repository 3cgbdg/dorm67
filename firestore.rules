rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /** Keys changed on this write (Firestore map diff). */
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    /** Anyone signed in may bump likes / comment count; core post fields stay owner-only. */
    function announcementSocialOnlyUpdate() {
      let keys = changedKeys();
      return keys.hasOnly(['likedBy', 'likesCount'])
        || keys.hasOnly(['commentsCount'])
        || keys.hasOnly(['likedBy', 'likesCount', 'commentsCount']);
    }

    function commentSocialOnlyUpdate() {
      return changedKeys().hasOnly(['likedBy', 'likesCount']);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      
      match /savedListings/{listingId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Listings (Marketplace)
    match /listings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Announcements (Campus Feed)
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isOwner(resource.data.userId);
      allow update: if isAuthenticated() && (
        isOwner(resource.data.userId) || announcementSocialOnlyUpdate()
      );

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isOwner(resource.data.userId);
        allow update: if isAuthenticated() && (
          isOwner(resource.data.userId) || commentSocialOnlyUpdate()
        );
      }
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated();

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    // AI Tasks Queue
    match /aiTasks/{taskId} {
      allow read, write: if isAuthenticated() && (
        (request.resource != null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // AI Chat History
    match /aiChats/{userId} {
      allow read: if isOwner(userId);
      match /messages/{msgId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Notifications
    match /notifications/{userId} {
      allow read: if isOwner(userId);
      match /items/{itemId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated() &&
          request.resource.data.keys().hasOnly([
            'title', 'body', 'type', 'refId', 'isRead', 'createdAt'
          ]) &&
          request.resource.data.title is string &&
          request.resource.data.body is string &&
          request.resource.data.type is string &&
          request.resource.data.refId is string &&
          request.resource.data.isRead == false &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.type in ['announcement', 'message'];
        allow update, delete: if isOwner(userId);
      }
    }

    // Taras lab reports — server writes only; client may read own job summaries
    match /aiTarasJobs/{userId} {
      allow read, write: if false;
      match /jobs/{jobId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    match /aiTarasUsage/{docId} {
      allow read, write: if false;
    }

    match /aiTarasRate/{docId} {
      allow read, write: if false;
    }

    match /aiTarasIdempotency/{docId} {
      allow read, write: if false;
    }
  }
}
